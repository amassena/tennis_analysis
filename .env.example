# Tennis Analysis Pipeline - Environment Variables
# Copy to .env and fill in your values

# ── iCloud Integration ─────────────────────────────────────
ICLOUD_USERNAME=your-icloud-email@example.com
ICLOUD_PASSWORD=xxxx-xxxx-xxxx-xxxx

# ── Email Notifications ────────────────────────────────────
GMAIL_SENDER=your-email@gmail.com
GMAIL_APP_PASSWORD=xxxx xxxx xxxx xxxx
SMS_EMAIL=1234567890@msg.fi.google.com

# ── Cloud Infrastructure (optional) ───────────────────────
# Only needed if CLOUD["enabled"] = True in config/settings.py

# Hetzner - Orchestration server
HETZNER_HOST=playfullife.com
HETZNER_API_TOKEN=your-hetzner-api-token

# RunPod - GPU burst processing
# Get API key from: https://runpod.io/console/user/settings
RUNPOD_API_KEY=your-runpod-api-key

# Cloudflare R2 - Video storage
# Get credentials from: Cloudflare Dashboard > R2 > Manage R2 API Tokens
CF_ACCOUNT_ID=your-cloudflare-account-id
CF_R2_ACCESS_KEY_ID=your-r2-access-key
CF_R2_SECRET_ACCESS_KEY=your-r2-secret-key
